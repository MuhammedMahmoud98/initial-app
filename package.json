{
  "name": "unified-qr-code",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build:mygate": "ng build --configuration=mygate --deploy-url=/qr-code/ --base-href=/qr-code/",
    "build:mygate-prod": "ng build --configuration=mygate-prod --deploy-url=/qr-code/ --base-href=/qr-code/",
    "build:prod": "ng build --configuration=production --deploy-url=/qr-code/ --base-href=/qr-code/",
    "build:dev": "ng build --configuration=dev --deploy-url=/qr-code/ --base-href=/qr-code/",
    "build:dev-qr": "ng build --configuration=dev --deploy-url=/qr-code/ --base-href=/qr-code/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint-current-changes": "npx eslint $(git diff --name-only HEAD | xargs)",
    "stylelint": "stylelint 'src/**/*.scss' --fix",
    "lint": "npx eslint",
    "prepare": "husky install",
    "build:elements": "ng run unified-qr-code:elements-build:production --single-bundle true --output-hashing=none",
    "bundle:elements": "node esbuild.elements.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.7",
    "@angular/common": "^19.2.7",
    "@angular/compiler": "^19.2.7",
    "@angular/core": "^19.2.7",
    "@angular/elements": "^19.2.25",
    "@angular/forms": "^19.2.7",
    "@angular/platform-browser": "^19.2.7",
    "@angular/platform-browser-dynamic": "^19.2.7",
    "@angular/router": "^19.2.7",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "@primeng/themes": "^19.1.0",
    "jsencrypt": "^3.3.2",
    "ngx-cookie-service": "^19.1.2",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^19.1.0",
    "rxjs": "~7.8.0",
    "stylelint-config-recommended": "^16.0.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.8",
    "@angular/cli": "^19.2.8",
    "@angular/compiler-cli": "^19.2.7",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/jasmine": "~5.1.0",
    "@types/pdfmake": "^0.2.11",
    "angular-eslint": "^19.3.0",
    "esbuild": "^0.18.11",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "husky": "^9.1.7",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^15.5.1",
    "ngx-build-plus": "^19.0.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.19.1",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.11.1",
    "typescript": "~5.5.4",
    "typescript-eslint": "^8.31.0"
  }
}
